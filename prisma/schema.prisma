generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  plan         Plan      @default(FREE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  apiKeys      ApiKey[]
  uploads      Upload[]
  payments     Payment[]
}

model ApiKey {
  id           String   @id @default(uuid())
  keyHash      String   @unique
  userId       String
  usage        Int      @default(0)
  monthlyLimit Int      @default(10)
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?
  
  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([keyHash])
  @@index([userId])
}

model Upload {
  id        String   @id @default(uuid())
  userId    String
  valor     Float?
  data      DateTime?
  banco     String?
  pagador   String?
  recebedor String?
  txId      String?
  rawText   String?
  fileName  String?
  fileType  String?
  createdAt DateTime @default(now())
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
}

model Payment {
  id                String   @id @default(uuid())
  userId            String
  paguebitPaymentId String   @unique
  status            PaymentStatus @default(PENDING)
  amount            Float
  qrCodeUrl         String?
  qrCopyPaste       String?
  observation       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([paguebitPaymentId])
  @@index([status])
}

enum Plan {
  FREE
  PRO
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}
